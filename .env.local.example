# ====================================
# 学术社交模拟器 - 环境变量配置
# 复制此文件为 .env.local 并填写
# ====================================

# 应用地址（部署后改为你的域名）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- 支付宝配置 ----
# 在 https://open.alipay.com 创建应用获取
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# 正式环境用: https://openapi.alipay.com/gateway.do
# 沙箱环境用: https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ---- 微信支付配置 ----
# 在 https://pay.weixin.qq.com 获取
WECHAT_MCH_ID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_API_V3_KEY=

# ---- 其他 ----
CRON_SECRET=your-random-secret-string
